#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
GENERATED_SPEC="$ROOT_DIR/openapi/oapi-codegen-input.yml"
trap 'rm -f "$GENERATED_SPEC"' EXIT

cd "$ROOT_DIR"

go generate ./generated/...
go run ./scripts/generate_wrappers
gofmt -s -w generated/openapi.gen.go generated_apis.go discovery.go tables.go
